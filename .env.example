PORT=5000
MONGO_URI=your_mongodb_connection_string
JWT_SECRET=your_app_jwt_secret
FRONTEND_URL=http://localhost:3000
NODE_ENV=production
TRUST_PROXY=true
BODY_LIMIT=1mb
ENABLE_RATE_LIMIT=true
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=50
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_JWT_KEY=your_clerk_jwt_public_key

# Google OAuth itself should be configured in the Clerk dashboard.
# Do not store raw Google client_id/client_secret in this app env file.
